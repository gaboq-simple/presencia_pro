# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Mismo proyecto Supabase que el resto del monorepo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # servidor únicamente — NUNCA en el cliente

# ─── WHATSAPP BUSINESS API ────────────────────────────────────────────────────
# Token del System User del Meta Business Account del operador.
# Un solo token sirve para todos los negocios — cada negocio usa su propio
# whatsapp_phone_number_id almacenado en la tabla businesses.
WHATSAPP_ACCESS_TOKEN=
# String aleatorio para verificar el webhook con Meta (GET /api/bot).
# Configurar el mismo valor en Meta Developers → Webhooks → Verify Token.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret del Meta App — para verificar la firma X-Hub-Signature-256.
# Obtener en Meta Developers → Tu App → App Settings → Basic → App Secret.
# Obligatorio en producción. Sin esta variable, el webhook rechaza todos los requests con 401.
META_APP_SECRET=

# ─── CLAUDE API ───────────────────────────────────────────────────────────────
# Clave compartida con el resto del monorepo — un solo API key.
ANTHROPIC_API_KEY=

# ─── AUTENTICACIÓN EDGE FUNCTIONS ─────────────────────────────────────────────
# Secret compartido entre Supabase Edge Functions y los API Routes de lifestyle.
# El API Route valida: Authorization: Bearer ${CRON_SECRET}
# Agregar el mismo valor en Supabase Secrets.
CRON_SECRET=

# ─── TWILIO (solo desarrollo) ─────────────────────────────────────────────────
# Remover o dejar vacío cuando Meta Business Manager esté activo.
# Obtener en twilio.com/console → Account Info.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número del Sandbox de Twilio para WhatsApp (fijo, no cambiar).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# URL pública del webhook (ngrok u otro túnel local).
# Configurar en Twilio Console → Messaging → Sandbox settings → "WHEN A MESSAGE COMES IN".
NGROK_URL=
# UUID del negocio a usar en desarrollo (Sandbox de Twilio usa un número compartido
# y no puede resolverse por phone_number_id — usar este fallback).
TWILIO_DEV_BUSINESS_ID=

# ─── MESSAGING PROVIDER ────────────────────────────────────────────────────────
# 'twilio' en desarrollo (Sandbox sin aprobación de Meta).
# 'meta' en producción (Meta Business Cloud API).
# Swap sin tocar lógica de negocio.
MESSAGING_PROVIDER=twilio

# ─── APP ──────────────────────────────────────────────────────────────────────
# URL pública del app en producción.
# Usada para construir URLs absolutas en notificaciones y redirecciones.
NEXT_PUBLIC_APP_URL=                 # ej: https://lifestyle.presenciapro.com

# ─── UPSTASH REDIS (rate limiting) ──────────────────────────────────────────
# Necesarias para rate limiting distribuido en producción.
# Obtener en console.upstash.com → tu base Redis → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
